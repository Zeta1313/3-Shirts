<aside class="cart-sidebar">
  <div class="cart-box">
    
    <div class="cart-header">
      <div class="cart-header-left">
        <h2 class="cart-title">Shopping Cart</h2>
        <p class="cart-subtitle">Your selected items will appear here.</p>
      </div>

      <div class="cart-count-badge">
        <span id="cart-count">0</span>
      </div>
    </div>

    
    <div id="empty-cart" class="empty-cart">
      <div class="empty-cart-icon">🛒</div>
      <h3>Your cart is empty</h3>
      <p>Add products from the catalog or product page to see them here.</p>
    </div>

   
    <ul id="cart-items" class="cart-items">
      
    </ul>

    
    <div class="cart-footer">
      <div class="cart-total-row">
        <span class="cart-total-label">Subtotal</span>
        <span id="cart-total" class="cart-total-value">$0.00</span>
      </div>

      <div class="cart-actions">
        <button id="clear-cart-btn" class="clear-cart-btn" type="button">
          Clear Cart
        </button>

        <button id="checkout-btn" class="checkout-btn" type="button">
          Checkout
        </button>
      </div>

      
    </div>
  </div>
</aside>