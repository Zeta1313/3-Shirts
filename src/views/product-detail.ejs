<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

<%- include('partials/header') %>

<main class="container product-detail-page">

  <a class="back-btn" href="/products">← Back to products</a>

  <div class="product-detail-card">

    <!-- Product Image -->
    <div class="product-detail-image">
      <% if (product.Image) { %>
        <img src="/<%= product.Image %>" alt="<%= product.Name %>">
      <% } else { %>
        <img src="/images/PlainShirt.png">
      <% } %>
    </div>

    <!-- Product Info -->
    <div class="product-detail-info">

      <h1 class="product-title">
        <%= product.Name %>
      </h1>

      <p class="product-price">
        $<%= Number(product.Price).toFixed(2) %>
      </p>

      <p class="product-desc">
        <%= product.Description %>
      </p>

      <div class="product-meta">
        <span class="pill"><%= product.Brand %></span>
        <span class="pill"><%= product.Pattern %></span>
        <span class="pill"><%= product.Size %></span>
        <span class="pill"><%= product.Color %></span>
        <span class="pill"><%= Stock %></span>
      </div>

      <a class="add-to-cart-btn center-wide" href="/api/cart/items">Add to cart</a>

    </div>

  </div>

</main>

<%- include('partials/footer') %>

</body>
</html>