<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/cart.css">
  <link rel="icon" type="image/x-icon" href="/images/Favicon2.png">
  <script src="/js/filters.js" defer></script>
  <script src="/js/cart.js" defer></script>
</head>

<body>

  <%- include('partials/header') %>

    <main class="container products-layout">

      <%- include('partials/cart-sidebar') %>

        <section class="products-content">
          <h2>Recent Pages</h2>

          <div class="filter-bar">
            <div class="filter-group">
              <label for="sizeSelect">Size</label>
              <select id="sizeSelect">
                <option value="All">All Sizes</option>
                <% sizes.forEach(size=> { %>
                  <option value="<%= size %>">
                    <%= size %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="filter-group">
              <label for="colorSelect">Color</label>
              <select id="colorSelect">
                <option value="All">All Colors</option>
                <% colors.forEach(color=> { %>
                  <option value="<%= color %>">
                    <%= color %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="filter-group">
              <label for="brandSelect">Brand</label>
              <select id="brandSelect">
                <option value="All">All Brands</option>
                <% brands.forEach(brand=> { %>
                  <option value="<%= brand %>">
                    <%= brand %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="filter-group">
              <label for="sortSelect">Sort</label>
              <select id="sortSelect">
                <option value="price_asc">Price: Low to High</option>
                <option value="price_desc">Price: High to Low</option>
              </select>
            </div>

            <div class="filter-group">
              <button id="clearFilters" type="button">Clear</button>

              <div class="results-meta">
                <span id="productCount">
                  Showing <strong>
                    <%= products.length %>
                  </strong> products
                </span>
              </div>
            </div>


          </div>

          <section class="products-grid">
            <% if (!products || products.length===0) { %>

              <div class="empty-state">
                <h3>No products available</h3>
                <p>Products will appear here once you've visited our pages.</p>
              </div>

              <% } else { %>

                <% for (let i=0; i < products.length; i++) { %>
                  <div class="product-card">

                    <div class="product-image">
                      <% if (products[i].Image) { %>
                        <img src="/<%= products[i].Image %>" alt="<%= products[i].Name %>">
                        <% } else { %>
                          <img src="/images/PlainShirt.png" alt="Plain Shirt">
                          <% } %>
                    </div>

                    <h3 class="product-title">
                      <%= products[i].Name %>
                    </h3>

                    <p class="product-price">
                      $<%= Number(products[i].Price).toFixed(2) %>
                    </p>

                    <p class="product-desc">
                      <%= products[i].Description %>
                    </p>

                    <div class="product-meta">
                      <span class="pill">
                        <%= products[i].Brand %>
                      </span>
                      <span class="pill">
                        <%= products[i].Pattern %>
                      </span>
                      <span class="pill">
                        <%= products[i].Size %>
                      </span>
                      <span class="pill">
                        <%= products[i].Color %>
                      </span>
                    </div>

                    <div class="product-actions">
                      <a class="view-btn" href="/products/<%= products[i].ID %>">
                        View product
                      </a>

                      <button class="add-to-cart-btn" data-id="<%= products[i].ID %>" type="button">
                        Add to cart
                      </button>
                    </div>

                  </div>
                  <% } %>

                    <% } %>
          </section>
        </section>

    </main>

    <%- include('partials/footer') %>

</body>

</html>